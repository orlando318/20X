# Profile: dev | paper | live
POLY_MODE=dev

# Polymarket API credentials
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Polygon wallet (required for live order submission)
POLY_PRIVATE_KEY=
POLY_WALLET_ADDRESS=

# Connection tuning (optional — sensible defaults provided)
# POLY_CONN_REQUEST_TIMEOUT=10.0
# POLY_CONN_MAX_RETRIES=5
# POLY_CONN_RATE_LIMIT_PER_SECOND=10

# Risk overrides (optional — profile defaults applied per mode)
# POLY_RISK_MAX_POSITION_USD=100.0
# POLY_RISK_MAX_DRAWDOWN_PCT=5.0
# POLY_RISK_KILL_SWITCH_LOSS_USD=50.0

# Logging
# POLY_LOG_LEVEL=DEBUG
# POLY_LOG_FILE=poly.log
